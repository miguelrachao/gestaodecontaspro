<div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
    <ul class="navbar-nav flex-grow-1">
        <li class="nav-item">
            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Início</a>
        </li>
        @{
            if (User?.Identity?.IsAuthenticated == false)
            {
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="About">Sobre</a>
                </li>
            }
            else
            {
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Profile" asp-action="Index">Perfis</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Entry" asp-action="Index">Registos</a>
                </li>
            }

        }
       
    </ul>
    @{
        if (User?.Identity?.IsAuthenticated == true)
        {
            <ul class="navbar-nav align-items-end ms-auto">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="margin-right: 25px;">@User.Identity.Name</a>
                    <ul class="dropdown-menu">
                        <li class="ms-2"><a class="nav-link" asp-controller="Account" asp-action="Details">Conta</a></li>
                        <li class="ms-2"><a class="nav-link" asp-controller="Account" asp-action="Logout">Sair</a></li>
                    </ul>
                </li>
            </ul>
        }
    }
</div>