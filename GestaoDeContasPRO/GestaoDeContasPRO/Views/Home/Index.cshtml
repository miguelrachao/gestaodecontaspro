@using System.Globalization
@using System.Text.Json
@{
    ViewData["Title"] = "Início";

    if (Model.error)
    {
        <p>Ocorreu um erro.</p>
    }
    else
    {
        if (Model.profiles.Count == 0)
        {
            <div class="text-center">
                <h3 class="mt-5">Bem vindo ao gestor de contas</h3>
                <h5 class="mt-5">Para começar, <a href="~/Profile/Add">adicione um perfil</a></h5>
            </div>
        }
        else
        {
            <form method="get" class="mb-3">

                <div class="filter-card">

                    <div class="row g-2">

                        <div class="col-12 col-lg-4">
                            <div class="d-flex gap-2">

                                <select name="profileId"
                                        class="form-select form-control"
                                        onchange="this.form.submit()">

                                    @foreach (var profile in Model.profiles)
                                    {
                                        <option value="@profile.Id" selected="@(profile.Id == Model.profileId)">
                                            @profile.Name
                                        </option>
                                    }

                                </select>

                                <a href="~/Entry/Add?profileId=@Model.profileId"><img src="~/img/add.png" style="width:35px;" class="ms-1 mt-1" /></a>

                            </div>
                        </div>

                        <div class="col-6 col-lg-4">
                            <input name="startDate"
                                   type="date"
                                   class="form-control"
                                   value="@Model.startDate"
                                   onchange="this.form.submit()" />
                        </div>

                        <div class="col-6 col-lg-4">
                            <input name="endDate"
                                   type="date"
                                   class="form-control"
                                   value="@Model.endDate"
                                   onchange="this.form.submit()" />
                        </div>

                    </div>

                </div>

            </form>


            <div class="row g-2 mb-3">

                <div class="col-4">
                    <div class="summary-card">
                        <small class="summary-title stats-category summary-credit">Créditos</small>
                        <div class="stats-value">
                            @Model.credit.ToString("N2", new CultureInfo("pt-PT")) €
                        </div>
                    </div>
                </div>

                <div class="col-4">
                    <div class="summary-card">
                        <small class="summary-title stats-category summary-debit">Débitos</small>
                        <div class="stats-value">
                            @Model.debit.ToString("N2", new CultureInfo("pt-PT")) €
                        </div>
                    </div>
                </div>

                <div class="col-4">
                    <div class="summary-card">
                        <small class="summary-title stats-category summary-balance">Balanço</small>
                        <div class="stats-value">
                            @Model.balance.ToString("N2", new CultureInfo("pt-PT")) €
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-2">

                @foreach (Entry entry in Model.entriesAmount)
                {
                    var percent = entry.Category.BudgetCoverage;

                    <div class="col-6 col-md-4 col-lg-3 col-xl-2">

                        <a asp-controller="Entry"
                           asp-action="Index"
                           asp-route-profileId="@entry.ProfileId"
                           asp-route-categoryId="@entry.Category.Id"
                           asp-route-startDate="@Model.startDate"
                           asp-route-endDate="@Model.endDate"
                           class="text-decoration-none">

                            <div class="stats-card h-100">

                                <div class="stats-category">
                                    @entry.Category.Name
                                </div>

                                <div>
                                    <div class="stats-value">
                                        @entry.Amount.ToString("N2", new CultureInfo("pt-PT")) €
                                    </div>
                                    @{
                                        if (entry.AverageAmount > 0)
                                        {
                                            <div class="stats-value" style="font-size: 9pt;">
                                                Média: @entry.AverageAmount.ToString("N2", new CultureInfo("pt-PT")) €
                                            </div>
                                        }
                                    }
                                </div>

                                <div class="d-flex justify-content-between align-items-center mt-2">

                                    <div class="progress flex-grow-1 me-2" style="height:4px;">
                                        <div class="progress-bar @(percent > 100 ? "bg-danger" : percent >= 80 ? "bg-warning" : "bg-success")"
                                             role="progressbar"
                                             style="width:@Math.Min(percent, 100)%;"></div>
                                    </div>

                                    <small class="@(percent > 100 ? "text-danger" : percent >= 80 ? "text-warning" : "text-success")">
                                        @percent.ToString("N0")%
                                    </small>

                                </div>

                            </div>

                        </a>

                    </div>
                }

            </div>

            <div class="row mt-3">

                <div class="col-12">

                    <div class="stats-card" style="cursor: context-menu;">

                        <div class="card-header fw-semibold">
                            Balanço anual
                        </div>

                        <div class="card-body p-3">

                            <div style="height:340px">
                                <canvas id="chart"></canvas>
                            </div>

                        </div>

                    </div>

                </div>

            </div>
   
            <script>
                const yearBalances = @Html.Raw(JsonSerializer.Serialize(Model.yearBalances));
                const credits = yearBalances.map(x => x.Credit);
                const debits = yearBalances.map(x => x.Debit);
                const balances = yearBalances.map(x => x.Balance);

                const monthNames = [
                    "Jan", "Fev", "Mar", "Abr", "Mai", "Jun",
                    "Jul", "Ago", "Set", "Out", "Nov", "Dez"
                ];

                const labels = yearBalances.map(x => monthNames[x.Month - 1]);
                const ctx = document.getElementById('chart');

                               const balanceColors = balances.map(v =>
                    v >= 0 ? '#3b82f6' : '#ef4444'
                );

                new Chart(ctx, {

                    type: 'bar',

                    data: {
                        labels: labels,

                        datasets: [
                        {
                            label: 'Crédito',
                            data: credits,
                            backgroundColor: '#22c55e',
                            borderRadius: 6,
                            borderSkipped: false,
                            barPercentage: 0.85,
                            categoryPercentage: 0.65
                        },
                        {
                            label: 'Débito',
                            data: debits,
                            backgroundColor: '#ef4444',
                            borderRadius: 6,
                            borderSkipped: false,
                            barPercentage: 0.85,
                            categoryPercentage: 0.65
                        },
                        {
                            label: 'Balanço',
                            data: balances,
                            backgroundColor: balanceColors,
                            borderRadius: 6,
                            borderSkipped: false,
                            barPercentage: 0.85,
                            categoryPercentage: 0.65
                        }]
                    },

                    options: {

                        responsive: true,
                        maintainAspectRatio: false,

                        animation: {
                            duration: 900
                        },

                        interaction: {
                            mode: 'index',
                            intersect: false
                        },

                        plugins: {

                            legend: {

                                position: 'top',
                                align: 'end',

                                labels: {
                                    color: '#cfd8dc',
                                    boxWidth: 18,
                                    boxHeight: 10,
                                    padding: 18,
                                    usePointStyle: true,
                                    pointStyle: 'rectRounded'
                                }
                            },

                            tooltip: {

                                backgroundColor: '#1f2937',

                                callbacks: {
                                    label: function (context) {

                                        return context.dataset.label + ': ' +
                                            context.parsed.y.toLocaleString('pt-PT', {
                                                style: 'currency',
                                                currency: 'EUR'
                                            });

                                    }
                                }
                            }

                        },

                        scales: {

                            x: {

                                grid: {
                                    display: false
                                },

                                ticks: {
                                    color: '#adb5bd'
                                }

                            },

                            y: {

                                beginAtZero: true,

                                grid: {
                                    color: 'rgba(255,255,255,.05)'
                                },

                                ticks: {

                                    color: '#adb5bd',

                                    callback: function(value) {

                                        return value.toLocaleString('pt-PT') + " €";

                                    }

                                }

                            }

                        }

                    }

                });
            </script>
        }
    }
    
}