@{
    ViewData["Title"] = "Erro";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
    <div class="card shadow-lg border-0" style="max-width: 420px; border-radius: 16px;">

        <div class="card-body text-center p-4">

            <div class="mb-3">
                <div class="rounded-circle bg-danger bg-opacity-10 d-inline-flex align-items-center justify-content-center"
                     style="width: 64px; height: 64px;">
                    <span class="fs-3 text-danger">⚠️</span>
                </div>
            </div>

            <h5 class="card-title fw-bold text-danger">
                Ocorreu um erro
            </h5>

            <p class="card-text text-muted mt-2">
                Não foi possível concretizar o pedido.<br>
                Por favor, volte novamente mais tarde.
            </p>

        </div>
    </div>
</div>